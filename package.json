    "@prisma/client": "^7.4.0",
    "@xyflow/react": "^12.6.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.2.3",
    "google-auth-library": "^9.15.1",
    "googleapis": "^167.0.0",
    "gray-matter": "^4.0.3",
    "jose": "^6.1.3",
    "lucide-react": "^0.552.0",
    "mssql": "^12.2.0",
    "next": "^16.0.7",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
