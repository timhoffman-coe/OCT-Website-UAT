    "db:generate": "npx prisma generate",
    "generate-icons": "npx tsx scripts/generate-pwa-icons.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
