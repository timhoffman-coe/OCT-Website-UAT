generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH & PERMISSIONS
// ============================================================

enum Role {
  SUPER_ADMIN
  TEAM_ADMIN
  VIEWER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamPermissions              TeamPermission[]
  auditLogs                    AuditLog[]
  roadmapPermission            RoadmapPermission?
  octWebDevPermission          OctWebDevPermission?
  newsPermission               NewsPermission?
  projectPermission            ProjectPermission?
  linksPermission              LinksPermission?
  policiesPermission           PoliciesPermission?
  projectManagerAssignments    ProjectManagerAssignment[]
}

model TeamPermission {
  id     String @id @default(cuid())
  userId String
  teamId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
}

model RoadmapPermission {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OctWebDevPermission {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("OctWebDevPermission")
}

model NewsPermission {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProjectPermission {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LinksPermission {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PoliciesPermission {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String
  description String?
  changes     Json     @default("{}")
  status      String   @default("SUCCESS")
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

// ============================================================
// ANALYTICS: PAGE VIEWS
// ============================================================

model PageView {
  id        String   @id @default(cuid())
  path      String
  teamSlug  String?
  userAgent String?
  referrer  String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([teamSlug])
  @@index([createdAt])
}

// ============================================================
// CONTENT: TEAMS
// ============================================================

enum PageTemplate {
  ITS_TEAM
  SECTION
  SUB_TEAM
  CUSTOM
}

model Team {
  id            String       @id @default(cuid())
  slug          String       @unique
  teamName      String
  teamShortName String
  pageTemplate  PageTemplate @default(ITS_TEAM)
  sortOrder     Int          @default(0)
  isPublished   Boolean      @default(true)
  archivedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Fields for SectionTemplate pages
  pageTitle       String?
  pageDescription String?

  // Fields for SubTeam pages
  iconName   String?
  showStatus Boolean @default(false)

  // Parent-child hierarchy (sections contain teams, teams contain sub-teams)
  parentId String?
  parent   Team?  @relation("TeamHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Team[] @relation("TeamHierarchy")

  portfolios      Portfolio[]
  teamTabs        TeamTab[]
  trelloBoards    TrelloBoard[]
  teamMembers     TeamMember[]
  accordionGroups AccordionGroup[]
  serviceAreas    ServiceArea[]
  teamPermissions TeamPermission[]
  widgetInstances WidgetInstance[]
  teamServices    TeamService[]
  teamInitiatives TeamInitiative[]
  teamContacts    TeamContact[]
  teamQuickLinks  TeamQuickLink[]
  whoWeAreItems   WhoWeAreItem[]
  keyInitiativeSlides KeyInitiativeSlide[]

  linkedFromPortfolio    Portfolio?   @relation("PortfolioLinkedTeam")
  linkedFromServiceArea  ServiceArea? @relation("ServiceAreaLinkedTeam")

  @@index([parentId])
}

// ============================================================
// CONTENT: PORTFOLIOS (ITS team building blocks)
// ============================================================

model Portfolio {
  id           String  @id @default(cuid())
  teamId       String
  iconName     String
  title        String
  description  String
  href         String
  sortOrder    Int     @default(0)
  linkedTeamId String? @unique

  team       Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  linkedTeam Team?             @relation("PortfolioLinkedTeam", fields: [linkedTeamId], references: [id], onDelete: SetNull)
  subpage    PortfolioSubpage?

  @@index([teamId])
}

model TeamTab {
  id                  String @id @default(cuid())
  teamId              String
  tabId               String
  label               String
  videoTitle          String
  videoDescription    String
  videoUrl            String
  diagramsTitle       String
  diagramsDescription String
  sortOrder           Int    @default(0)

  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  diagramLinks DiagramLink[]

  @@index([teamId])
}

model DiagramLink {
  id        String @id @default(cuid())
  teamTabId String
  label     String
  href      String
  sortOrder Int    @default(0)

  teamTab TeamTab @relation(fields: [teamTabId], references: [id], onDelete: Cascade)
}

model TrelloBoard {
  id          String @id @default(cuid())
  teamId      String
  title       String
  description String
  href        String
  sortOrder   Int    @default(0)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model TeamMember {
  id        String @id @default(cuid())
  teamId    String
  name      String
  title     String
  email     String
  sortOrder Int    @default(0)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

// ============================================================
// CONTENT: ACCORDION / IMPORTANT LINKS
// ============================================================

model AccordionGroup {
  id        String  @id @default(cuid())
  teamId    String?
  groupId   String
  title     String
  sortOrder Int     @default(0)

  team  Team?           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  links AccordionLink[]

  @@index([teamId])
}

model AccordionLink {
  id        String @id @default(cuid())
  groupId   String
  label     String
  href      String
  sortOrder Int    @default(0)

  group AccordionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

// ============================================================
// CONTENT: PORTFOLIO SUBPAGES
// ============================================================

model PortfolioSubpage {
  id             String  @id @default(cuid())
  portfolioId    String  @unique
  parentTeam     String
  parentTeamHref String
  title          String
  description    String
  iconName       String
  showStatus     Boolean @default(true)

  portfolio   Portfolio           @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  services    SubpageService[]
  initiatives SubpageInitiative[]
  contacts    SubpageContact[]
  quickLinks  SubpageQuickLink[]
}

model SubpageService {
  id        String   @id @default(cuid())
  subpageId String
  title     String
  items     String[]
  sortOrder Int      @default(0)

  subpage PortfolioSubpage @relation(fields: [subpageId], references: [id], onDelete: Cascade)
}

model SubpageInitiative {
  id          String @id @default(cuid())
  subpageId   String
  title       String
  description String
  href        String
  sortOrder   Int    @default(0)

  subpage PortfolioSubpage @relation(fields: [subpageId], references: [id], onDelete: Cascade)
}

model SubpageContact {
  id        String @id @default(cuid())
  subpageId String
  name      String
  role      String
  email     String
  sortOrder Int    @default(0)

  subpage PortfolioSubpage @relation(fields: [subpageId], references: [id], onDelete: Cascade)
}

model SubpageQuickLink {
  id          String  @id @default(cuid())
  subpageId   String
  label       String
  description String
  href        String
  isSecure    Boolean @default(false)
  sortOrder   Int     @default(0)

  subpage PortfolioSubpage @relation(fields: [subpageId], references: [id], onDelete: Cascade)
}

// ============================================================
// CONTENT: SERVICE AREAS (SectionTemplate pages)
// ============================================================

model ServiceArea {
  id               String   @id @default(cuid())
  teamId           String
  serviceAreaId    String
  title            String
  shortDescription String
  fullDescription  String
  features         String[]
  icon             String?
  link             String?
  sortOrder        Int      @default(0)
  linkedTeamId     String?  @unique

  team       Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  linkedTeam Team? @relation("ServiceAreaLinkedTeam", fields: [linkedTeamId], references: [id], onDelete: SetNull)

  @@index([teamId])
}

// ============================================================
// WIDGET-BASED PAGE BUILDER
// ============================================================

model WidgetDefinition {
  id          String  @id @default(cuid())
  widgetType  String  @unique
  label       String
  description String?
  icon        String  @default("LayoutGrid")
  isEnabled   Boolean @default(true)

  instances WidgetInstance[]
}

model WidgetInstance {
  id                 String  @id @default(cuid())
  teamId             String?
  projectId          String?
  widgetDefinitionId String
  sortOrder          Int     @default(0)
  config             Json?

  team             Team?            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project          Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  widgetDefinition WidgetDefinition @relation(fields: [widgetDefinitionId], references: [id], onDelete: Restrict)

  @@unique([teamId, widgetDefinitionId])
  @@unique([projectId, widgetDefinitionId])
  @@index([teamId, sortOrder])
  @@index([projectId, sortOrder])
}

// ============================================================
// CONTENT: SUB-TEAM PAGE DATA
// ============================================================

model TeamService {
  id        String   @id @default(cuid())
  teamId    String
  title     String
  items     String[]
  sortOrder Int      @default(0)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model TeamInitiative {
  id          String @id @default(cuid())
  teamId      String
  title       String
  description String
  href        String
  sortOrder   Int    @default(0)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model TeamContact {
  id        String @id @default(cuid())
  teamId    String
  name      String
  role      String
  email     String
  sortOrder Int    @default(0)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model TeamQuickLink {
  id          String  @id @default(cuid())
  teamId      String
  label       String
  description String
  href        String
  isSecure    Boolean @default(false)
  sortOrder   Int     @default(0)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

// ============================================================
// CONTENT: WHO WE ARE (SectionTemplate pages)
// ============================================================

model WhoWeAreItem {
  id          String @id @default(cuid())
  teamId      String
  title       String
  description String
  linkText    String @default("Learn More")
  linkUrl     String
  sortOrder   Int    @default(0)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

// ============================================================
// CONTENT: KEY INITIATIVE SLIDES (SectionTemplate pages)
// ============================================================

model KeyInitiativeSlide {
  id          String  @id @default(cuid())
  teamId      String
  title       String
  description String
  imageUrl    String?
  imageAlt    String  @default("")
  sortOrder   Int     @default(0)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

// ============================================================
// CONTENT: ROADMAP
// ============================================================

model RoadmapSection {
  id        String   @id @default(cuid())
  title     String
  color     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects RoadmapProject[]
}

model RoadmapProject {
  id           String   @id @default(cuid())
  sectionId    String
  name         String
  owner        String
  startYear    Int
  endYear      Int
  startQuarter Int
  endQuarter   Int
  progress     Int      @default(0)
  description  String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  section RoadmapSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

// ============================================================
// CONTENT: PROJECTS
// ============================================================

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

model Project {
  id          String        @id @default(cuid())
  slug        String        @unique
  projectCode String?
  title       String
  description String?
  status      ProjectStatus @default(PLANNING)

  // Governance
  department            String?
  branch                String?
  projectSponsor        String?
  projectManager        String?
  octProgramManager     String?
  octltRepresentative   String?
  programManagerBusiness String?

  // Financial
  totalBudget          String?
  fundingSources       String?
  expenditureAuthority String?

  // Timeline
  startDate DateTime?
  endDate   DateTime?
  progress  Int       @default(0)

  // Publishing
  isPublished Boolean   @default(false)
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  milestones         ProjectMilestone[]
  objectives         ProjectObjective[]
  statusUpdates      ProjectStatusUpdate[]
  tags               ProjectTagAssignment[]
  managerAssignments ProjectManagerAssignment[]
  widgetInstances    WidgetInstance[]

  @@index([status])
  @@index([isPublished])
}

model ProjectMilestone {
  id        String   @id @default(cuid())
  projectId String
  name      String
  date      DateTime?
  status    String   @default("upcoming") // "completed", "current", "upcoming"
  sortOrder Int      @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectObjective {
  id          String  @id @default(cuid())
  projectId   String
  iconName    String?
  title       String
  description String
  sortOrder   Int     @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectStatusUpdate {
  id        String   @id @default(cuid())
  projectId String
  content   String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
}

model ProjectTag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  projects ProjectTagAssignment[]
}

model ProjectTagAssignment {
  id        String @id @default(cuid())
  projectId String
  tagId     String

  project Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag     ProjectTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([projectId, tagId])
  @@index([tagId])
}

model ProjectManagerAssignment {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
}

// ============================================================
// CONTENT: LINKS PAGE
// ============================================================

model LinkCategory {
  id        String   @id @default(cuid())
  title     String
  subtitle  String
  iconBg    String   @default("bg-blue-50")
  iconColor String   @default("text-process-blue")
  isTeamGrid Boolean @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  links LinkItem[]
}

model LinkItem {
  id         String   @id @default(cuid())
  categoryId String
  name       String
  url        String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category LinkCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

// ============================================================
// CONTENT: POLICIES PAGE
// ============================================================

model Policy {
  id          String   @id @default(cuid())
  title       String
  type        String
  code        String
  category    String
  description String
  url         String
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
